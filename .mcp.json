{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--output-dir",
        ".playwright-mcp/output"
      ],
      "env": {}
    },
    "yandex-cloud-docs": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@yandex-cloud/mcp", "-s", "docs", "--no-auth"]
    }
  }
}